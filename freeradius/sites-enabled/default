server default {
  listen {
    type = auth
    ipaddr = *
    port = 1812
  }

  listen {
    type = acct
    ipaddr = *
    port = 1813
  }

  authorize {
    preprocess
    chap
    mschap
    digest
    suffix
    eap {
      ok = return
    }
    files
    expiration
    logintime
    sql
    pap
  }

  authenticate {
    Auth-Type PAP {
      pap
    }
    Auth-Type CHAP {
      chap
    }
    Auth-Type MS-CHAP {
      mschap
    }
  }

  preacct {
    preprocess
    acct_unique
    suffix
    files
  }

  accounting {
    detail
    sql
    exec
    attr_filter.accounting_response
  }

  post-auth {
    sql
    Post-Auth-Type REJECT {
      sql
      attr_filter.access_reject
    }
  }
}
