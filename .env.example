COMPOSE_PROJECT_NAME=radius_kisaanu
TZ=Asia/Kolkata
MYSQL_VOLUME_NAME=radius_kisaanu_mysql_data

# Copy this file to .env (production) or .env.local (local)
MYSQL_ROOT_PASSWORD=REPLACE_ME_MYSQL_ROOT_PASSWORD
MYSQL_DATABASE=radius
MYSQL_USER=radius
MYSQL_PASSWORD=REPLACE_ME_MYSQL_APP_PASSWORD

RADIUS_DB_NAME=radius
RADIUS_DB_USER=radius
RADIUS_DB_PASS=REPLACE_ME_MYSQL_APP_PASSWORD
RADIUS_DB_HOST=mysql

RADIUS_SHARED_SECRET=REPLACE_ME_RADIUS_SHARED_SECRET
RADIUS_CLIENT_NAME=omada-eap225-outdoor
RADIUS_CLIENT_IP=REPLACE_ME_OMADA_CLIENT_SUBNET
OMADA_CONTROLLER_IP=REPLACE_ME_OMADA_CONTROLLER_IP
# Keep 0 for cloud + RADIUS-only mode. Set 1 only when portal can reach target/portal/auth.
OMADA_TARGET_CALLBACK_ENABLED=0

NGINX_BIND_IP=0.0.0.0
NGINX_HTTP_PORT=8090
DALORADIUS_BIND_IP=0.0.0.0
DALORADIUS_HTTP_PORT=8091
PHPMYADMIN_BIND_IP=0.0.0.0
PHPMYADMIN_HTTP_PORT=8092
RADIUS_BIND_IP=0.0.0.0
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
